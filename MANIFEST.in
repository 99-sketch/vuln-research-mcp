# Include README and license
include README.md
include LICENSE

# Include requirements file
include requirements.txt

# Include installation script
include install.ps1

# Include Claude desktop config example
include claude_desktop_config_example.json

# Include all Python files in src and tests
recursive-include src *.py
recursive-include tests *.py

# Include GitHub workflows
recursive-include .github/workflows *.yml

# Exclude unnecessary files
exclude __pycache__
exclude *.pyc
exclude .DS_Store
exclude Thumbs.db
